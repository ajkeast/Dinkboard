# MySQL connection (host may optionally include ":port")
SQL_HOST=db.example.com:3306
SQL_USER=dbuser
SQL_PASSWORD=changeme
SQL_DATABASE=mydatabase

# HTTP — code default is 5000. On macOS, AirPlay Receiver often binds 5000;
# if so, use PORT=5001 (and point client VITE_API_BASE_URL at that port).
PORT=5000
CORS_ORIGIN=http://localhost:3000,http://localhost:5173,http://localhost

# Auth
JWT_SECRET=generate-a-long-random-secret
# COOKIE_SECURE=false
# Optional overrides (defaults shown)
# ACCESS_TOKEN_TTL_SECONDS=900
# REFRESH_TOKEN_TTL_DAYS=30
# AUTH_RATE_LIMIT=10
# API_RATE_LIMIT=300
# NODE_ENV=development

# Discord OAuth (optional — enables "Continue with Discord" on login/register)
# Create an app at https://discord.com/developers/applications → OAuth2
# Redirect URI in the portal must exactly match DISCORD_REDIRECT_URI.
# DISCORD_CLIENT_ID=
# DISCORD_CLIENT_SECRET=
# DISCORD_REDIRECT_URI=http://localhost:5001/api/auth/discord/callback
# CLIENT_URL=http://localhost:3000
