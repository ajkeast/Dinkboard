# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules/
/node_modules
**/node_modules
/.pnp
.pnp.js

# npm workspaces — single root lockfile only
client/package-lock.json
server/package-lock.json
e2e/package-lock.json

# testing
/coverage
/e2e/test-results
/e2e/playwright-report
/e2e/blob-report
/e2e/.auth

# production / build outputs
/build
/dist
client/dist/
client/build/
server/coverage/

# local smoke / visual evidence (not for commit)
smoke-evidence/
client/smoke-evidence/
e2e/screenshots/

# env secrets — never commit
.env
**/.env
.env.*
!.env.example
!**/.env.example

# misc
.DS_Store
.env.local
.env.development.local
.env.test.local
.env.production.local

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs
*.log

# Fly.io
fly.toml
**/fly.toml

# IDE
.idea/
.vscode/
*.swp
*.swo
