{
  "name": "dinkboard",
  "version": "1.0.0",
  "description": "Discord analytics dashboard — Express + MySQL API, React/Vite + MUI client.",
  "private": true,
  "workspaces": [
    "client",
    "server",
    "e2e"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:client dev:server",
    "dev:client": "npm run dev -w client",
    "dev:server": "npm run dev -w server",
    "start": "npm-run-all --parallel start:client start:server",
    "start:client": "npm run dev -w client",
    "start:server": "npm run start -w server",
    "build": "npm run build -w client",
    "migrate": "npm run migrate -w server",
    "test": "npm run test -w server",
    "test:e2e": "npm run test -w e2e"
  },
  "keywords": [
    "dinkboard",
    "express",
    "mysql",
    "react",
    "vite"
  ],
  "author": "ajkeast",
  "license": "ISC",
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
